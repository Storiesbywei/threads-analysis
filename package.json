{
  "name": "threads-analysis",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone Threads corpus analysis — information theory, knowledge graphs, discourse taxonomy for @maybe_foucault",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "sync": "node scripts/threads-sync.mjs",
    "sync:replies": "node scripts/threads-backfill-replies.mjs",
    "sync:metrics": "node scripts/threads-backfill-metrics.mjs",
    "analyze": "node scripts/analysis/information-theory.mjs && node scripts/analysis/knowledge-graph.mjs",
    "full": "npm run sync && npm run analyze",
    "worker": "node scripts/sync-worker.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "seed:json": "node scripts/seed-from-json.mjs",
    "docker:db": "docker compose up -d",
    "docker:data": "docker compose --profile data up -d",
    "docker:web": "docker compose --profile web up -d",
    "docker:all": "docker compose --profile full up -d",
    "docker:down": "docker compose --profile full down",
    "docker:logs": "docker compose --profile full logs -f",
    "docker:rebuild": "docker compose --profile full up -d --build",
    "api": "node scripts/api-server.mjs",
    "embed": "node scripts/embed-posts.mjs",
    "enrich": "node scripts/enrich-posts.mjs",
    "haiku": "node scripts/haiku-agent.mjs",
    "haiku:loop": "node scripts/haiku-agent.mjs --loop",
    "genealogy": "node scripts/tech-genealogy.mjs",
    "pedagogy": "node scripts/pedagogy-genealogy.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/node": "^9.0.0",
    "@astrojs/react": "^4.0.0",
    "@types/three": "^0.183.1",
    "astro": "^5.17.0",
    "force-graph": "^1.47.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
