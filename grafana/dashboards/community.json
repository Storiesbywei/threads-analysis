        "format": "table",
        "rawSql": "SELECT c.reply_timestamp AS time, c.reply_username AS who, LEFT(c.reply_text, 150) AS reply, LEFT(p.text, 100) AS original_post\nFROM conversations c\nJOIN posts p ON p.id = c.root_post_id\nORDER BY c.reply_timestamp DESC\nLIMIT 20",
