        "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
        "format": "table",
        "rawSql": "SELECT reply_username,\n  COUNT(*) AS total,\n  COUNT(*) FILTER (WHERE reply_timestamp >= NOW() - INTERVAL '30 days') AS last_30d,\n  COUNT(*) FILTER (WHERE reply_timestamp >= NOW() - INTERVAL '90 days') AS last_90d,\n  MIN(reply_timestamp)::date AS first_reply,\n  MAX(reply_timestamp)::date AS last_reply\nFROM conversations\nWHERE reply_username IS NOT NULL AND reply_username != 'maybe_foucault'\nGROUP BY reply_username\nORDER BY total DESC LIMIT 15",
        "refId": "A"
      }],
      "title": "Inner Circle — Monthly Interaction Heatmap",
      "type": "table"
