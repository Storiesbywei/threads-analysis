      "targets": [{
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
        "format": "table",
        "rawSql": "SELECT \n  CASE \n    WHEN cnt = 1 THEN '1 reply'\n    WHEN cnt BETWEEN 2 AND 3 THEN '2-3 replies'\n    WHEN cnt BETWEEN 4 AND 5 THEN '4-5 replies'\n    ELSE '6+ replies'\n  END AS depth,\n  COUNT(*) AS posts\nFROM (SELECT root_post_id, COUNT(*) AS cnt FROM conversations GROUP BY root_post_id) sub\nGROUP BY 1\nORDER BY 1",
        "refId": "A"
      }],
      "title": "Conversation Depth",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "depth": "Depth",
              "posts": "Posts"
            }
          }
