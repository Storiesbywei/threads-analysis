        "rawSql": "SELECT t.tag, COUNT(c.*) AS reply_count\nFROM conversations c\nJOIN tags t ON t.post_id = c.root_post_id\nGROUP BY t.tag\nORDER BY reply_count DESC LIMIT 15",
        "refId": "A"
      }],
      "title": "Topics That Generate Discussion",
      "transformations": [
