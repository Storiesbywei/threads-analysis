          "format": "table",
          "rawSql": "SELECT p.timestamp::date AS date, LEFT(p.text, 200) AS post,\n  m.views, m.likes, m.replies, m.reposts, m.quotes,\n  p.sentiment, p.energy\nFROM posts p JOIN metrics_latest m ON m.post_id = p.id\nORDER BY m.views DESC NULLS LAST LIMIT 15",
