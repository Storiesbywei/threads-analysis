      "id": 10,
      "options": {
        "xTickLabelRotation": 0,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "threads-pg"
          },
          "format": "table",
          "rawSql": "SELECT CASE EXTRACT(DOW FROM p.timestamp)\n  WHEN 0 THEN 'Sun' WHEN 1 THEN 'Mon' WHEN 2 THEN 'Tue'\n  WHEN 3 THEN 'Wed' WHEN 4 THEN 'Thu' WHEN 5 THEN 'Fri' WHEN 6 THEN 'Sat'\n  END AS day,\n  COUNT(*) AS posts,\n  ROUND(AVG(m.views)) AS avg_views\nFROM posts p LEFT JOIN metrics_latest m ON m.post_id = p.id\nGROUP BY 1, EXTRACT(DOW FROM p.timestamp)\nORDER BY EXTRACT(DOW FROM p.timestamp)",
          "refId": "A"
        }
      ],
      "title": "Day of Week Performance",
      "type": "barchart"
