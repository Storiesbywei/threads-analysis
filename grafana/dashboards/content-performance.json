      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "threads-pg"
          },
          "format": "table",
          "rawSql": "SELECT\n  CASE\n    WHEN views < 100 THEN '0-100'\n    WHEN views < 500 THEN '100-500'\n    WHEN views < 1000 THEN '500-1K'\n    WHEN views < 5000 THEN '1K-5K'\n    WHEN views < 10000 THEN '5K-10K'\n    WHEN views < 50000 THEN '10K-50K'\n    WHEN views < 100000 THEN '50K-100K'\n    ELSE '100K+'\n  END AS range,\n  COUNT(*) AS posts\nFROM metrics_latest WHERE views > 0\nGROUP BY 1\nORDER BY MIN(views)",
          "refId": "A"
        }
      ],
      "title": "Views Distribution",
      "type": "barchart"
    },
