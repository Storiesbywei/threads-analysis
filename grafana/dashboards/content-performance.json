      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "threads-pg"
          },
          "format": "table",
          "rawSql": "SELECT LPAD(EXTRACT(HOUR FROM p.timestamp)::text, 2, '0') || ':00' AS hour,\n  ROUND(AVG(m.views)) AS avg_views,\n  ROUND(AVG(m.likes), 1) AS avg_likes\nFROM posts p JOIN metrics_latest m ON m.post_id = p.id\nGROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Engagement by Hour",
      "type": "barchart"
