      "id": 11,
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "avg_views"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "threads-pg"
          },
          "format": "table",
          "rawSql": "SELECT t.tag,\n  COUNT(*) AS posts,\n  ROUND(AVG(m.views)) AS avg_views,\n  ROUND(AVG(m.likes), 1) AS avg_likes,\n  ROUND(AVG(m.replies), 1) AS avg_replies,\n  ROUND(AVG(s.surprise)::numeric, 2) AS avg_surprise\nFROM tags t\nLEFT JOIN metrics_latest m ON m.post_id = t.post_id\nLEFT JOIN surprise_scores s ON s.post_id = t.post_id\nGROUP BY t.tag\nHAVING COUNT(*) >= 5\nORDER BY avg_views DESC NULLS LAST\nLIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Tag Engagement Matrix",
      "type": "table"
