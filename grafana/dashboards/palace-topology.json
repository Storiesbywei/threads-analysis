    {
      "id": 6,
      "type": "stat",
      "title": "Cross-Links",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM tp_edges WHERE relationship <> 'contains'",
