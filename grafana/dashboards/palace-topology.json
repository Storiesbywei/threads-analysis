{
  "uid": "palace-topology",
  "title": "Thread Palace",
  "schemaVersion": 39,
  "editable": true,
  "timezone": "browser",
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
        "query": "SELECT DISTINCT SPLIT_PART(node_id, ':', 2) AS __value, SPLIT_PART(node_id, ':', 2) AS __text FROM tp_nodes WHERE node_type = 'wing' GROUP BY 1 ORDER BY 1",
        "current": { "text": "all-minilm", "value": "all-minilm" },
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "sort": 0
      },
      {
        "name": "wing",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
        "query": "SELECT node_id AS __value, label || ' (' || COALESCE((metadata->>'size')::text, '?') || ' posts)' AS __text FROM tp_nodes WHERE node_type = 'wing' AND node_id LIKE 'wing:' || '${model}' || ':%' ORDER BY (metadata->>'size')::int DESC NULLS LAST",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 0
      },
      {
        "name": "room",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
        "query": "SELECT n.node_id AS __value, n.label AS __text FROM tp_edges e JOIN tp_nodes n ON n.node_id = e.target_id WHERE e.source_id = '${wing}' AND e.relationship = 'contains' AND n.node_type = 'room' ORDER BY n.label",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Palace Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Wings",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "threads-pg" },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM tp_nodes WHERE node_type = 'wing'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
