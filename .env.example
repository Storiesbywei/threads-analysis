# Threads API — get token at developers.facebook.com → Threads API product
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_USERNAME=
APP_ID=
THREADS_APP_ID=
APP_SECRETS=
THREADS_USER_SECRETS=

# Postgres (defaults work for local Docker)
POSTGRES_PASSWORD=threads_local_dev
DATABASE_URL=postgres://threads:threads_local_dev@localhost:5433/threads

# Sync worker
SYNC_INTERVAL_MINUTES=30
METRICS_BATCH_SIZE=200
FULL_SYNC_ON_START=false

# API server
PORT=4322
HOST=0.0.0.0
OLLAMA_URL=http://localhost:11434
APFEL_URL=http://localhost:11435

# Monitoring
ALERT_PHONE=
