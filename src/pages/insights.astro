---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import KLTimeline from '../components/react/KLTimeline';
import SentimentChart from '../components/react/SentimentChart';
import VoiceConsistency from '../components/react/VoiceConsistency';
---
<Layout title="Insights">
  <h1>Insights</h1>
  <p class="page-desc">
    Information-theoretic analysis of voice drift, audience sentiment, and vocabulary consistency.
  </p>

  <div class="section">
    <h2 class="section-title">Voice Drift (KL Divergence)</h2>
    <p class="section-desc">
      How much does your posting voice deviate week-to-week from your overall baseline?
      Spikes indicate weeks where your topic distribution was statistically unusual.
    </p>
    <KLTimeline client:load />
  </div>

  <div class="section">
    <h2 class="section-title">Reply Sentiment</h2>
    <p class="section-desc">
      Keyword-based sentiment analysis of replies from your audience.
      Shows the emotional tone of how people respond to your posts.
    </p>
    <SentimentChart client:load />
  </div>

  <div class="section">
    <h2 class="section-title">Voice Consistency</h2>
    <p class="section-desc">
      Monthly type-token ratio (vocabulary diversity) and tag entropy (topic diversity) over time.
      Higher TTR means more diverse word choice; higher entropy means broader topic coverage.
    </p>
    <VoiceConsistency client:load />
  </div>
</Layout>

<style>
  .page-desc {
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
    margin-top: var(--space-sm);
    margin-bottom: var(--space-xl);
    max-width: 640px;
    line-height: 1.5;
  }

  .section {
    margin-bottom: var(--space-2xl);
  }

  .section-title {
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .section-desc {
    color: var(--text-tertiary);
    font-size: var(--font-size-xs);
    margin-bottom: var(--space-md);
    max-width: 560px;
    line-height: 1.5;
  }
</style>
