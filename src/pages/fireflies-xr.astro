---
export const prerender = false;
import FirefliesXR from '../components/react/FirefliesXR';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Fireflies XR — Threads Analysis</title>
  <meta name="description" content="40K Threads posts as luminous particles in immersive WebXR — spatial computing for Apple Vision Pro" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧵</text></svg>" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #020208;
      color: #e6edf3;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    #xr-root {
      width: 100vw;
      height: 100vh;
      position: fixed;
      top: 0;
      left: 0;
    }
    .back-link {
      position: fixed;
      bottom: 16px;
      right: 16px;
      z-index: 100;
      color: rgba(255,255,255,0.25);
      font-size: 11px;
      font-family: monospace;
      text-decoration: none;
      padding: 4px 10px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px;
      background: rgba(2,2,8,0.7);
      backdrop-filter: blur(8px);
      transition: color 0.2s, border-color 0.2s;
    }
    .back-link:hover {
      color: rgba(255,255,255,0.6);
      border-color: rgba(255,255,255,0.2);
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div id="xr-root">
    <FirefliesXR client:only="react" />
  </div>
  <a href="/fireflies" class="back-link">&larr; 2D fireflies</a>
</body>
</html>
