              <td class="mi-value" style={`background: ${miCellColor(pair.normalizedMI)};`}>
                {pair.normalizedMI.toFixed(4)}
              </td>
              <td class="mi-interp">
                {pair.interpretation}
              </td>
              <td class="mi-bar-cell">
                <div class="mi-bar" style={`width: ${miBarWidth(pair.normalizedMI)}%;`}></div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mi-legend">
      <span class="mi-legend-item"><span class="mi-swatch" style="background: #3fb95066;"></span> Strong</span>
      <span class="mi-legend-item"><span class="mi-swatch" style="background: #3fb95044;"></span> Moderate</span>
      <span class="mi-legend-item"><span class="mi-swatch" style="background: #3fb95028;"></span> Weak</span>
      <span class="mi-legend-item"><span class="mi-swatch" style="background: #8b949e10;"></span> Independent</span>
    </div>
  </div>
</Layout>

